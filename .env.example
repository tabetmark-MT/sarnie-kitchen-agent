# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server (set automatically by Render)
APP_URL=https://your-app-name.onrender.com
PORT=3000

# Optional: Webhook security secret
WEBHOOK_SECRET=sarnie-agent-secret

# Optional: Morning debrief time (24h, Europe/London timezone)
MORNING_HOUR=9
MORNING_MINUTE=0

# Nightly off-site backup to Dropbox (24h, Europe/London timezone)
BACKUP_HOUR=23
BACKUP_MINUTE=0

# Dropbox backup credentials — see SETUP-DROPBOX.md for how to obtain these
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret
DROPBOX_REFRESH_TOKEN=your_dropbox_refresh_token
DROPBOX_BACKUP_PATH=/Sarnie Social Backups
